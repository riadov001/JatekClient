{
  "cli": {
    "version": ">= 1.0.0",
    "appVersionSource": "local"
  },
  "submit": {
    "production": {}
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "autoIncrement": true,
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleDebug"
      }
    },
    "preview": {
      "distribution": "internal",
      "autoIncrement": true,
      "channel": "main",
      "android": { "buildType": "apk" },
      "env": {
        "EXPO_PUBLIC_DOMAIN": "ma.jatek.app",
        "EXPO_PUBLIC_API_URL": "https://ma.jatek.app",
        "EXPO_PUBLIC_GOOGLE_MAPS_KEY": "$EXPO_PUBLIC_GOOGLE_MAPS_KEY",
        "EXPO_PUBLIC_GOOGLE_PLACES_KEY": "$EXPO_PUBLIC_GOOGLE_PLACES_KEY"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_DOMAIN": "ma.jatek.app",
        "EXPO_PUBLIC_API_URL": "https://ma.jatek.app",
        "EXPO_PUBLIC_GOOGLE_MAPS_KEY": "$EXPO_PUBLIC_GOOGLE_MAPS_KEY",
        "EXPO_PUBLIC_GOOGLE_PLACES_KEY": "$EXPO_PUBLIC_GOOGLE_PLACES_KEY"
      },
      "android": { "buildType": "app-bundle" }
    }
  }
}
