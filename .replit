modules = ["nodejs-24", "python-3.11", "postgresql-16"]

  [deployment]
  router = "application"
deploymentTarget = "autoscale"
run = ["bash", "scripts/start-production.sh"]
build = ["bash", "scripts/build-production.sh"]

  [deployment.postBuild]
  args = ["pnpm", "store", "prune"]
  env = { "CI" = "true" }

  [workflows]
runButton = "Project"

  [[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Publish to Expo Go (OTA)"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Build Android APK (Preview)"

  [[workflows.workflow]]
  name = "Build Android APK (Dev)"
  author = "agent"

  [[workflows.workflow.tasks]]
  task = "shell.exec"
  args = "bash scripts/build-android-dev.sh"

  [workflows.workflow.metadata]
  outputType = "console"

[[workflows.workflow]]
name = "Publish to Expo Go (OTA)"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash scripts/publish-expo-go.sh"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Build Android APK (Preview)"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash scripts/build-android-preview.sh"

[workflows.workflow.metadata]
outputType = "console"

  [agent]
  stack = "BEST_EFFORT_FALLBACK"
expertMode = true
  integrations = ["twilio:1.0.0"]

  [postMerge]
  path = "scripts/post-merge.sh"
  timeoutMs = 20000

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 5001
externalPort = 6000

[[ports]]
localPort = 8080
externalPort = 80

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 3003

[[ports]]
localPort = 18244
externalPort = 3000

[[ports]]
localPort = 18245
externalPort = 4200

[[ports]]
localPort = 19167
externalPort = 3001

[[ports]]
localPort = 25896
externalPort = 3002

[[ports]]
localPort = 25897
externalPort = 5173

  [nix]
  channel = "stable-25_05"
packages = ["eas-cli", "unzipNLS", "nox"]

  [userenv]

  [userenv.shared]

  [userenv.development]
  INFOBIP_WA_SENDER = "+15072600620"
  EXPO_PUBLIC_DOMAIN = "ma.jatek.app"

  [userenv.production]
  INFOBIP_WA_SENDER = "+15072600620"
  EXPO_PUBLIC_DOMAIN = "ma.jatek.app"
REPLIT_INTERNAL_APP_DOMAIN = "https://jatekmobile-apps.replit.app/"

  [objectStorage]
defaultBucketID = "replit-objstore-c3b1110b-7f6a-4490-b8de-ea32e9f24588"
  